---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Nasry Oussama | Data Analyst & Data Engineer';
const description = 'Portfolio Data Analyst : dashboards Grafana, KPI de production, Python, SQL.';
---

<BaseLayout title={title} description={description}>

<!-- ── NAV ── -->
<header class="nav" id="nav">
  <div class="nav-pill">
    <a class="brand" href="#home" aria-label="Accueil">
      <span class="brand-badge">ON</span>
      <span class="brand-name">Oussama Nasry</span>
    </a>
    <nav class="nav-links" aria-label="Navigation">
      <a class="nav-link" href="#home" data-i18n="nav.home">Accueil</a>
      <a class="nav-link" href="#projects" data-i18n="nav.projects">Projets</a>
      <a class="nav-link" href="#skills" data-i18n="nav.skills">Compétences</a>
      <a class="btn btn-glass btn-sm" href="/cv-oussama_nasry.pdf" target="_blank" rel="noreferrer" data-i18n="nav.cv">CV PDF</a>
      <div class="lang-toggle" role="group" aria-label="Langue / Language">
        <span class="lang-opt active" data-lang="fr" role="button" tabindex="0">FR</span>
        <span class="lang-opt" data-lang="en" role="button" tabindex="0">EN</span>
      </div>
    </nav>
  </div>
</header>

<!-- ── HERO ── -->
<section class="hero" id="home" aria-label="Présentation">
  <canvas id="heroCanvas" aria-hidden="true"></canvas>

  <div class="container">
    <div class="hero-inner">

      <div class="hero-text">
        <div class="hero-badge" id="heroBadge" data-i18n="hero.badge">
          <span class="pulse-dot" aria-hidden="true"></span>
          En alternance · Solustil
        </div>
        <h1 class="hero-name">
          <span class="split-line"><span class="split-word" id="hw1">Oussama</span></span>
          <span class="split-line"><span class="split-word grad-text" id="hw2">Nasry</span></span>
        </h1>
        <p class="hero-role" id="heroRole">
          Data Analyst<span class="sep">·</span>Data Engineer
        </p>
        <p class="hero-sub" id="heroSub" data-i18n="hero.sub">
          Je transforme des données industrielles brutes<br />
          en dashboards actionnables et insights clairs.
        </p>
        <div class="hero-cta" id="heroCta">
          <a class="btn btn-green mag-btn" href="#projects" data-i18n="hero.cta1">Voir mes projets</a>
          <a class="btn btn-glass mag-btn" href="#contact" data-i18n="hero.cta2">Me contacter</a>
        </div>
      </div>

      <div class="hero-scene" id="heroScene">
        <div class="photo-tilt" id="photoTilt">
          <img src="/IMG_7324.png" alt="Oussama Nasry" />
          <div class="photo-overlay" aria-hidden="true"></div>
          <div class="photo-shine"  aria-hidden="true"></div>
          <div class="stat-bubble sb-top">
            <span class="sb-val">3<sup>ème</sup></span>
            <span class="sb-label" data-i18n="hero.sbTop">Année BUT SD</span>
          </div>
          <div class="stat-bubble sb-bot">
            <span class="sb-val">4+</span>
            <span class="sb-label" data-i18n="hero.sbBot">Projets livrés</span>
          </div>
        </div>
      </div>

    </div>
  </div>

  <div class="scroll-hint" aria-hidden="true">
    <div class="scroll-mouse"><span class="scroll-wheel"></span></div>
    <span data-i18n="hero.scroll">Défiler</span>
  </div>
</section>

<!-- ── NUMBERS ── -->
<div class="numbers-strip">
  <div class="container">
    <div class="nums-grid">
      <div class="num-cell gs-up">
        <span class="num-val" data-i18n="nums.1val">3ème</span>
        <span class="num-label" data-i18n="nums.1">Année BUT Science des données</span>
      </div>
      <div class="num-cell gs-up">
        <span class="num-val" data-i18n="nums.2val">1 an+</span>
        <span class="num-label" data-i18n="nums.2">Alternance industrielle</span>
      </div>
      <div class="num-cell gs-up">
        <span class="num-val">4+</span>
        <span class="num-label" data-i18n="nums.3">Projets data livrés</span>
      </div>
      <div class="num-cell gs-up">
        <span class="num-val">3</span>
        <span class="num-label" data-i18n="nums.4">Langues maîtrisées</span>
      </div>
    </div>
  </div>
</div>

<!-- ── EXPÉRIENCE ── -->
<section class="section" id="experience" aria-labelledby="xp-h">
  <div class="container">
    <div class="xp-grid">

      <div class="gs-left">
        <span class="eyebrow" data-i18n="xp.eyebrow">Expérience phare</span>
        <h2 id="xp-h" data-i18n="xp.h">Alternance · Analyse<br />&amp; Reporting de Production</h2>
        <p class="lead" data-i18n="xp.lead">Chez Solustil, je prépare et exploite les données de production pour alimenter des tableaux de bord opérationnels — de la donnée brute à l'indicateur clair.</p>
        <ul class="feature-list" role="list">
          <li class="feature-item">
            <div class="f-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" width="17" height="17"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 2.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" /></svg>
            </div>
            <div class="f-text">
              <strong data-i18n="xp.f1t">Préparation des données</strong>
              <p data-i18n="xp.f1p">Nettoyage, détection d'anomalies et structuration des données issues des lignes de production.</p>
            </div>
          </li>
          <li class="feature-item">
            <div class="f-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" width="17" height="17"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" /></svg>
            </div>
            <div class="f-text">
              <strong data-i18n="xp.f2t">Production de tableaux de bord</strong>
              <p data-i18n="xp.f2p">Conception de dashboards (rendement, rebut, charge machine) en SQL, DAX et intégration HTML/JSON.</p>
            </div>
          </li>
          <li class="feature-item">
            <div class="f-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" width="17" height="17"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
            </div>
            <div class="f-text">
              <strong data-i18n="xp.f3t">Fiabilisation des rapports</strong>
              <p data-i18n="xp.f3p">Contrôle qualité des données pour garantir des indicateurs cohérents et exploitables.</p>
            </div>
          </li>
        </ul>
      </div>

      <div class="gs-right">
        <div class="browser-scene">
          <div class="browser-frame">
            <div class="bbar">
              <span class="bdot"></span><span class="bdot"></span><span class="bdot"></span>
              <span class="burl">dashboard.solustil — Grafana</span>
            </div>
            <div class="bbody">
              <img class="zoomable" src="/projects/dashboard-machine.png" alt="Dashboard Grafana machines en temps réel" />
            </div>
          </div>
        </div>
        <p class="media-caption" data-i18n="xp.caption">Dashboard Grafana — aperçu réel</p>
      </div>

    </div>
  </div>
</section>

<!-- ── DASHBOARD REVEAL ── -->
<section class="reveal-section" aria-label="Dashboard plein écran">
  <div class="container">
    <span class="eyebrow" data-i18n="rv.eyebrow">Visualisation</span>
    <h2 data-i18n="rv.h">Un tableau de bord,<br />une décision.</h2>
    <p class="lead" style="max-width:460px;margin:0 auto" data-i18n="rv.lead">De la donnée brute à l'indicateur actionnable — en temps réel sur les lignes de production.</p>
  </div>
  <div class="reveal-frame" id="dashReveal">
    <img class="zoomable" src="/Dashnoard machine  plein ecran.png" alt="Dashboard machines plein écran" />
  </div>
</section>

<!-- ── À PROPOS ── -->
<section class="section-alt" aria-labelledby="about-h">
  <div class="container">
    <div class="s-header gs-up">
      <span class="eyebrow" data-i18n="about.eyebrow">Qui suis-je</span>
      <h2 id="about-h" data-i18n="about.h">À propos</h2>
      <p class="lead" style="max-width:600px" data-i18n="about.lead">Étudiant en 3<sup>ème</sup> année de BUT Science des données à l'IUT Lumière Lyon 2. Je maîtrise la chaîne complète de la donnée — de l'extraction SQL à la visualisation — et m'oriente vers l'ingénierie.</p>
    </div>
    <div class="about-grid">
      <div class="info-stack gs-left">
        <div class="info-item">
          <div class="i-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" width="16" height="16"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" /></svg>
          </div>
          <div><strong data-i18n="about.i1t">Formation</strong><span data-i18n="about.i1">BUT Science des données · IUT Lumière Lyon 2 (3ème année)</span></div>
        </div>
        <div class="info-item">
          <div class="i-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" width="16" height="16"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0M12 12.75h.008v.008H12v-.008z" /></svg>
          </div>
          <div><strong data-i18n="about.i2t">Alternance en cours</strong><span data-i18n="about.i2">Data Analyst · Solustil · Secteur industriel</span></div>
        </div>
        <div class="info-item">
          <div class="i-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" width="16" height="16"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 21l5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 016-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138c.896.061 1.785.147 2.666.257m-4.589 8.495a18.023 18.023 0 01-3.827-5.802" /></svg>
          </div>
          <div><strong data-i18n="about.i3t">Langues</strong><span data-i18n="about.i3">Français · Arabe · Anglais</span></div>
        </div>
        <div class="info-item">
          <div class="i-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" width="16" height="16"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
          </div>
          <div><strong data-i18n="about.i4t">Localisation</strong><span data-i18n="about.i4">Basé en France · Lyon &amp; région</span></div>
        </div>
      </div>

      <div class="dark-cards gs-right">
        <div class="dark-card">
          <h3 data-i18n="about.c1t">Ce qui me motive</h3>
          <p data-i18n="about.c1">Voir une équipe gagner du temps grâce à des indicateurs clairs. Transformer de la donnée brute en levier de décision opérationnel.</p>
        </div>
        <div class="dark-card">
          <h3 data-i18n="about.c2t">Compétences clés</h3>
          <p data-i18n="about.c2">Nettoyage de données, production de KPI, conception de dashboards, modélisation relationnelle et graphe.</p>
          <div class="tags"><span class="tag">SQL</span><span class="tag">Python</span><span class="tag">Grafana</span><span class="tag">Power BI</span><span class="tag">ETL</span></div>
        </div>
        <div class="dark-card">
          <h3 data-i18n="about.c3t">Cap sur l'ingénierie</h3>
          <p data-i18n="about.c3">Après la maîtrise de l'analyse et la visualisation, je développe mes compétences en Data Engineering — pipelines, modélisation et flux de données.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── PROJETS — flip cards ── -->
<section class="section" id="projects" aria-labelledby="proj-h">
  <div class="container">
    <div class="s-header gs-up">
      <span class="eyebrow" data-i18n="proj.eyebrow">Réalisations</span>
      <h2 id="proj-h" data-i18n="proj.h">Projets sélectionnés</h2>
      <p class="lead" style="max-width:520px" data-i18n="proj.lead">Professionnels &amp; académiques — centrés sur la valeur métier et la clarté des analyses.</p>
    </div>

    <div class="projects-grid">

      <!-- card 1 -->
      <div class="flip-wrap gs-scale">
        <div class="flip-card" tabindex="0" role="button" aria-label="Dashboard Grafana — voir les détails">
          <div class="flip-front">
            <div class="proj-img">
              <img src="/projects/dashboard-machine.png" alt="Dashboard Grafana machines" />
              <span class="proj-badge bp" data-i18n="badge.pro">Pro</span>
            </div>
            <div class="proj-body-front">
              <h3 data-i18n="card1.title">Dashboard machines en temps réel (Grafana)</h3>
              <p data-i18n="card1.front">Tableau de bord temps réel : machines en marche/arrêt, opérateurs par poste, opérations en cours.</p>
              <div class="flip-hint">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" width="12" height="12"><path stroke-linecap="round" stroke-linejoin="round" d="M15.042 21.672L13.684 16.6m0 0l-2.51 2.225.569-9.47 5.227 7.917-3.286-.672zM12 2.25V4.5m5.834.166l-1.591 1.591M20.25 10.5H18M7.757 14.743l-1.59 1.59M6 10.5H3.75m4.007-4.243l-1.59-1.59" /></svg>
                <span data-i18n="proj.hint">Cliquer pour les détails</span>
              </div>
            </div>
          </div>
          <div class="flip-back">
            <div class="flip-back-inner">
              <span class="proj-badge bp" data-i18n="card1.badgeBack">Pro · Solustil</span>
              <h3 data-i18n="card1.titleBack">Dashboard machines Grafana</h3>
              <p data-i18n="card1.back">Tableau de bord temps réel développé chez Solustil. Suivi machines, affectation opérateurs, opérations en cours. Requêtes SQL, plugin HTML et intégration JSON/Grafana.</p>
              <div class="tags"><span class="tag">Grafana</span><span class="tag">SQL</span><span class="tag">HTML</span><span class="tag">JSON</span></div>
              <div class="flip-back-close" data-i18n="proj.back">↩ Retourner</div>
            </div>
          </div>
        </div>
      </div>

      <!-- card 2 -->
      <div class="flip-wrap gs-scale">
        <div class="flip-card" tabindex="0" role="button" aria-label="Business Plan SHEMA — voir les détails">
          <div class="flip-front">
            <div class="proj-img">
              <img src="/projects/shema-2.png" alt="Business Plan automatisé SHEMA" />
              <span class="proj-badge bp" data-i18n="badge.pro">Pro</span>
            </div>
            <div class="proj-body-front">
              <h3 data-i18n="card2.title">Business Plan Automatisé (SHEMA)</h3>
              <p data-i18n="card2.front">Import multi-sources et automatisation des calculs via VBA et Excel pour fiabiliser un Business Plan.</p>
              <div class="flip-hint">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" width="12" height="12"><path stroke-linecap="round" stroke-linejoin="round" d="M15.042 21.672L13.684 16.6m0 0l-2.51 2.225.569-9.47 5.227 7.917-3.286-.672zM12 2.25V4.5m5.834.166l-1.591 1.591M20.25 10.5H18M7.757 14.743l-1.59 1.59M6 10.5H3.75m4.007-4.243l-1.59-1.59" /></svg>
                <span data-i18n="proj.hint">Cliquer pour les détails</span>
              </div>
            </div>
          </div>
          <div class="flip-back">
            <div class="flip-back-inner">
              <span class="proj-badge bp" data-i18n="card2.badgeBack">Pro · SHEMA</span>
              <h3 data-i18n="card2.titleBack">Business Plan Automatisé</h3>
              <p data-i18n="card2.back">Automatisation complète du BP SHEMA : import multi-sources, calculs en cascade VBA, contrôles de cohérence et mise en page dynamique. Réduction du temps de production de ~70%.</p>
              <div class="tags"><span class="tag">VBA</span><span class="tag">Excel</span><span class="tag">Automatisation</span></div>
              <div class="flip-back-close" data-i18n="proj.back">↩ Retourner</div>
            </div>
          </div>
        </div>
      </div>

      <!-- card 3 -->
      <div class="flip-wrap gs-scale">
        <div class="flip-card" tabindex="0" role="button" aria-label="Analyse Spatiale ANLCI — voir les détails">
          <div class="flip-front">
            <div class="proj-img">
              <img src="/projects/anlci-presence-cri-final.jpeg" alt="Carte présence CRI ANLCI" />
              <span class="proj-badge bs" data-i18n="badge.stage">Stage</span>
            </div>
            <div class="proj-body-front">
              <h3 data-i18n="card3.title">Analyse Spatiale (ANLCI)</h3>
              <p data-i18n="card3.front">Apurement de données, synthèse et cartographie QGIS pour le suivi d'indicateurs territoriaux de formation.</p>
              <div class="flip-hint">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" width="12" height="12"><path stroke-linecap="round" stroke-linejoin="round" d="M15.042 21.672L13.684 16.6m0 0l-2.51 2.225.569-9.47 5.227 7.917-3.286-.672zM12 2.25V4.5m5.834.166l-1.591 1.591M20.25 10.5H18M7.757 14.743l-1.59 1.59M6 10.5H3.75m4.007-4.243l-1.59-1.59" /></svg>
                <span data-i18n="proj.hint">Cliquer pour les détails</span>
              </div>
            </div>
          </div>
          <div class="flip-back">
            <div class="flip-back-inner">
              <span class="proj-badge bs" data-i18n="card3.badgeBack">Stage · ANLCI</span>
              <h3 data-i18n="card3.titleBack">Analyse Spatiale ANLCI</h3>
              <p data-i18n="card3.back">Apurement et normalisation de données territoriales. Production de cartes QGIS pour le suivi des Centres de Ressources Illettrisme (CRI) en France.</p>
              <div class="tags"><span class="tag">QGIS</span><span class="tag">Data Cleaning</span><span class="tag">Cartographie</span></div>
              <div class="flip-back-close" data-i18n="proj.back">↩ Retourner</div>
            </div>
          </div>
        </div>
      </div>

      <!-- card 4 -->
      <div class="flip-wrap gs-scale">
        <div class="flip-card" tabindex="0" role="button" aria-label="Migration Neo4j — voir les détails">
          <div class="flip-front">
            <div class="proj-img">
              <img src="/graph.png" alt="Graphe Neo4j crimes" />
              <span class="proj-badge be" data-i18n="badge.acad">Académique</span>
            </div>
            <div class="proj-body-front">
