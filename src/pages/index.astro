  };

  const i18nEls = Array.from(document.querySelectorAll<HTMLElement>('[data-i18n]'));
  const originalFR = new Map<HTMLElement, string>();
  i18nEls.forEach(el => originalFR.set(el, el.innerHTML));

  function setLang(lang: 'fr' | 'en') {
    document.documentElement.lang = lang;
    i18nEls.forEach(el => {
      const key = el.getAttribute('data-i18n')!;
      if (lang === 'en' && EN[key] != null) el.innerHTML = EN[key];
      else el.innerHTML = originalFR.get(el)!;
    });
    document.querySelectorAll<HTMLElement>('.lang-opt').forEach(o =>
      o.classList.toggle('active', o.dataset.lang === lang));
    try { localStorage.setItem('lang', lang); } catch {}
  }

  document.querySelectorAll<HTMLElement>('.lang-opt').forEach(opt => {
    const go = (e: Event) => { e.stopPropagation(); setLang(opt.dataset.lang as 'fr' | 'en'); };
    opt.addEventListener('click', go);
    opt.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); go(e); }
    });
  });

  try {
    if (localStorage.getItem('lang') === 'en') setLang('en');
  } catch {}

  /* ── Canvas particle network ── */
  interface Particle { x:number; y:number; vx:number; vy:number; r:number }

  const canvas = document.getElementById('heroCanvas') as HTMLCanvasElement | null;
  const ctx = canvas?.getContext('2d');
  if (canvas && ctx) {
    let W = canvas.width  = window.innerWidth;
    let H = canvas.height = window.innerHeight;
    window.addEventListener('resize', () => {
      W = canvas.width  = window.innerWidth;
      H = canvas.height = window.innerHeight;
    });
    const COUNT = Math.min(70, Math.floor(W / 20));
    const pts: Particle[] = Array.from({ length: COUNT }, () => ({
      x: Math.random() * W, y: Math.random() * H,
      vx: (Math.random() - 0.5) * 0.4,
      vy: (Math.random() - 0.5) * 0.4,
      r: Math.random() * 1.8 + 0.5,
    }));
    (function loop() {
      ctx.clearRect(0, 0, W, H);
      for (let i = 0; i < pts.length; i++) {
        const p = pts[i];
        p.x += p.vx; p.y += p.vy;
        if (p.x < 0 || p.x > W) p.vx *= -1;
        if (p.y < 0 || p.y > H) p.vy *= -1;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(37,99,235,0.65)';
        ctx.fill();
        for (let j = i + 1; j < pts.length; j++) {
          const q = pts[j];
          const dx = p.x - q.x, dy = p.y - q.y;
          const d = Math.sqrt(dx * dx + dy * dy);
          if (d < 130) {
            ctx.beginPath();
            ctx.moveTo(p.x, p.y);
            ctx.lineTo(q.x, q.y);
            ctx.strokeStyle = `rgba(37,99,235,${(0.16 * (1 - d / 130)).toFixed(3)})`;
            ctx.lineWidth = 0.7;
            ctx.stroke();
          }
        }
      }
      requestAnimationFrame(loop);
    })();
  }

  /* ── Hero entrance timeline ── */
  gsap.set('#heroScene', { x: 30 });
  const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
  tl
    .to('#heroBadge', { opacity:1, y:0, duration:.7 }, 0.2)
    .to(['#hw1','#hw2'], { opacity:1, y:0, duration:.85, stagger:.12 }, 0.4)
    .to('#heroRole',  { opacity:1, duration:.6 }, 0.85)
    .to('#heroSub',   { opacity:1, duration:.6 }, 1.0)
    .to('#heroCta',   { opacity:1, duration:.6 }, 1.15)
    .to('#heroScene', { opacity:1, x:0, duration:.9, ease:'power2.out' }, 0.5);

  /* ── ScrollTrigger reveals ── */
  const st = (sel: string, vars: gsap.TweenVars) =>
    gsap.utils.toArray<HTMLElement>(sel).forEach((el, i) =>
      gsap.to(el, { ...vars, delay: (i % 2) * 0.08,
        scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' } })
    );

  st('.gs-up',    { opacity:1, y:0,     duration:.7, ease:'power3.out' });
  st('.gs-left',  { opacity:1, x:0,     duration:.8, ease:'power3.out' });
  st('.gs-right', { opacity:1, x:0,     duration:.8, ease:'power3.out' });
  st('.gs-scale', { opacity:1, scale:1, duration:.65, ease:'power3.out' });

  /* ── Dashboard zoom reveal ── */
  const dashFrame = document.getElementById('dashReveal');
  if (dashFrame) {
    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => { if (e.isIntersecting) { dashFrame.classList.add('in-view'); obs.unobserve(dashFrame); } });
    }, { threshold: 0.12 });
    obs.observe(dashFrame);
  }

  /* ── 3D tilt — hero photo ── */
  const heroScene = document.getElementById('heroScene');
  const photoTilt = document.getElementById('photoTilt') as HTMLElement | null;
  if (heroScene && photoTilt) {
    let raf = 0;
    heroScene.addEventListener('mousemove', (e: MouseEvent) => {
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(() => {
        const r = photoTilt!.getBoundingClientRect();
        const x = (e.clientX - r.left) / r.width  - 0.5;
        const y = (e.clientY - r.top)  / r.height - 0.5;
        photoTilt!.style.transform = `perspective(1500px) rotateY(${x*9}deg) rotateX(${-y*9}deg)`;
      });
    });
    heroScene.addEventListener('mouseleave', () => {
      cancelAnimationFrame(raf);
      photoTilt!.style.transition = 'transform .6s cubic-bezier(0.4,0,0.2,1)';
      photoTilt!.style.transform  = 'perspective(1500px) rotateY(0deg) rotateX(0deg)';
      setTimeout(() => { photoTilt!.style.transition = 'transform .12s ease-out'; }, 620);
    });
  }

  /* ── Flip cards ── */
  document.querySelectorAll<HTMLElement>('.flip-card').forEach(card => {
    const toggle = () => card.classList.toggle('flipped');
    card.addEventListener('click', toggle);
    card.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggle(); }
    });
  });

  /* ── Magnetic buttons ── */
  document.querySelectorAll<HTMLElement>('.mag-btn').forEach(btn => {
    let rafM = 0;
    btn.addEventListener('mousemove', (e: MouseEvent) => {
      cancelAnimationFrame(rafM);
      rafM = requestAnimationFrame(() => {
        const r = btn.getBoundingClientRect();
        const x = (e.clientX - r.left - r.width  / 2) * 0.28;
        const y = (e.clientY - r.top  - r.height / 2) * 0.28;
        btn.style.transform = `translate(${x}px,${y}px)`;
      });
    });
    btn.addEventListener('mouseleave', () => {
      cancelAnimationFrame(rafM);
      btn.style.transition = 'transform .5s cubic-bezier(0.34,1.56,0.64,1)';
      btn.style.transform  = 'translate(0,0)';
      setTimeout(() => { btn.style.transition = ''; }, 520);
    });
  });

  /* ── Active nav link ── */
  const navLinks = document.querySelectorAll<HTMLAnchorElement>('.nav-link[href^="#"]');
  const sections = ['home','projects','skills','contact']
    .map(id => document.getElementById(id)).filter(Boolean) as HTMLElement[];
  const secObs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting)
        navLinks.forEach(l => l.classList.toggle('active', l.getAttribute('href') === `#${e.target.id}`));
    });
  }, { threshold: 0.38 });
  sections.forEach(s => secObs.observe(s));

  /* ── Lightbox ── */
  document.querySelectorAll<HTMLImageElement>('.zoomable').forEach(img => {
    img.addEventListener('click', () => {
      const lb = document.createElement('div');
      lb.className = 'lightbox';
      lb.innerHTML = `
        <div class="lightbox-bg"></div>
        <div class="lightbox-inner">
          <img src="${img.src}" alt="${img.alt}" />
          <button class="lightbox-close" type="button" aria-label="Fermer">✕</button>
        </div>`;
      document.body.appendChild(lb);
      document.body.style.overflow = 'hidden';
      const close = () => { lb.remove(); document.body.style.overflow = ''; };
      lb.querySelector('.lightbox-bg')!.addEventListener('click', close);
      lb.querySelector('.lightbox-close')!.addEventListener('click', close);
      document.addEventListener('keydown', function esc(ev) {
        if (ev.key === 'Escape') { close(); document.removeEventListener('keydown', esc); }
      });
    });
  });
</script>

</BaseLayout>
